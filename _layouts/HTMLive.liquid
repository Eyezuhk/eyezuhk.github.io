---
layout: default
---

<style>
    body {
        max-width: none;
        margin: 0;
        padding: 0;
    }
    .full-width {
        max-width: none !important;
    }
    .editor-preview {
        display: flex;
        flex-direction: row;
        height: calc(100vh - 60px);
        width: 100%;
    }
    #editor {
        width: 50%;
        padding: 10px;
        border-right: 1px solid #ccc;
        overflow-y: auto;
        white-space: pre-wrap;
        font-family: monospace;
    }
    #livePreview {
        width: 50%;
        padding: 10px;
        overflow-y: auto;
    }
    iframe {
        width: 100%;
        height: 100%;
        border: none;
    }
    .container {
        max-width: none;
    }
    .controls {
        padding: 10px;
        background-color: #f8f9fa;
        border-bottom: 1px solid #dee2e6;
    }
    .btn {
        margin-right: 5px;
    }
</style>

<div class="controls">
    <button class="btn btn-danger" onclick="clearEditor()">Clear</button>
    <button class="btn btn-primary" onclick="previewFullPage()">Preview Full Page</button>
    <button class="btn btn-info" onclick="importHTML()">Import</button>
    <button class="btn btn-success" onclick="exportHTML()">Export</button>
</div>

<div class="editor-preview">
    <div id="editor" contenteditable="true" spellcheck="true" placeholder="Coloque seu HTML aqui...">
        <h1>Hello, World!</h1>
        <p style="color: #00FF00; font-family: monospace;">Example: <strong>Hello, World!</strong></p>
    </div>
    <div id="livePreview">
        <iframe id="liveFrame"></iframe>       
    </div>
</div>

<script>
    const editor = document.getElementById('editor');
    const liveFrame = document.getElementById('liveFrame');

    // Função para processar o HTML antes de renderizar
    function processHTML(html) {
        // Remove espaços extras no início e fim
        return html.trim();
    }

    // Função para atualizar o preview
    function updatePreview() {
        const htmlContent = editor.innerHTML;
        const processedHTML = processHTML(htmlContent);
        liveFrame.srcdoc = processedHTML;
    }

    // Listener para mudanças no editor
    editor.addEventListener('input', updatePreview);

    // Função para visualizar em uma nova aba
    function previewFullPage() {
        const htmlContent = editor.innerHTML;
        const processedHTML = processHTML(htmlContent);
        const newWindow = window.open();
        newWindow.document.write(processedHTML);
        newWindow.document.close();
    }

    // Função para limpar o editor
    function clearEditor() {
        editor.innerHTML = '';
        liveFrame.srcdoc = '';
    }

    // Função para importar HTML de um arquivo
    function importHTML() {
        const input = document.createElement('input');
        input.type = 'file';
        input.accept = '.html';
        input.onchange = e => {
            const file = e.target.files[0];
            const reader = new FileReader();
            reader.onload = event => {
                editor.innerHTML = event.target.result;
                updatePreview();
            };
            reader.readAsText(file);
        };
        input.click();
    }

    // Função para exportar o conteúdo do editor para um arquivo
    function exportHTML() {
        const htmlContent = editor.innerHTML;
        const processedHTML = processHTML(htmlContent);
        const blob = new Blob([processedHTML], { type: 'text/html' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = 'export.html';
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
    }

    // Inicializa a visualização com o conteúdo padrão
    updatePreview();
</script>
